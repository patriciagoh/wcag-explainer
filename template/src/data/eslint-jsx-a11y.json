  "heading-has-content": {
    "criteria": [
      "1.3.1",
      "2.4.6"
    ],
    "description": "Headings must contain accessible content.",
    "url": "https://github.com/jsx-eslint/eslint-plugin-jsx-a11y/blob/main/docs/rules/heading-has-content.md"
