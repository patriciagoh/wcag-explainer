{
  "alt-text": {
    "criteria": [
      "1.1.1"
    ],
    "description": "Enforce alt text on img, area, input[type=image], and object.",
    "url": "https://github.com/jsx-eslint/eslint-plugin-jsx-a11y/blob/main/docs/rules/alt-text.md"
  },
  "anchor-has-content": {
    "criteria": [
      "2.4.4",
      "4.1.2"
    ],
    "description": "Anchors must have accessible, discernible content.",
    "url": "https://github.com/jsx-eslint/eslint-plugin-jsx-a11y/blob/main/docs/rules/anchor-has-content.md"
  },
  "anchor-is-valid": {
    "criteria": [
      "2.1.1"
    ],
    "description": "Anchors must be valid, navigable elements — not used as buttons.",
    "url": "https://github.com/jsx-eslint/eslint-plugin-jsx-a11y/blob/main/docs/rules/anchor-is-valid.md"
  },
  "aria-activedescendant-has-tabindex": {
    "criteria": [
      "4.1.2"
    ],
    "description": "Elements using aria-activedescendant must be tabbable.",
    "url": "https://github.com/jsx-eslint/eslint-plugin-jsx-a11y/blob/main/docs/rules/aria-activedescendant-has-tabindex.md"
