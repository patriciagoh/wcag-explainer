  },
  "no-redundant-roles": {
    "criteria": [
      "4.1.2"
    ],
    "description": "Don't set a role that an element already has implicitly.",
    "url": "https://github.com/jsx-eslint/eslint-plugin-jsx-a11y/blob/main/docs/rules/no-redundant-roles.md"
