  "scope": {
    "criteria": [
      "1.3.1"
    ],
    "description": "scope attribute should only be used on <th> elements.",
    "url": "https://github.com/jsx-eslint/eslint-plugin-jsx-a11y/blob/main/docs/rules/scope.md"
  },
  "tabindex-no-positive": {
    "criteria": [
      "2.4.3"
    ],
    "description": "Avoid positive tabindex — it breaks natural focus order.",
    "url": "https://github.com/jsx-eslint/eslint-plugin-jsx-a11y/blob/main/docs/rules/tabindex-no-positive.md"
  }
