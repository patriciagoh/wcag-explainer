  },
  "label-has-associated-control": {
    "criteria": [
      "1.3.1",
      "3.3.2",
      "4.1.2"
    ],
    "description": "<label> must be associated with a form control.",
    "url": "https://github.com/jsx-eslint/eslint-plugin-jsx-a11y/blob/main/docs/rules/label-has-associated-control.md"
  },
  "lang": {
    "criteria": [
      "3.1.1"
    ],
    "description": "lang attribute must have a valid value.",
    "url": "https://github.com/jsx-eslint/eslint-plugin-jsx-a11y/blob/main/docs/rules/lang.md"
  },
  "media-has-caption": {
    "criteria": [
      "1.2.2"
    ],
    "description": "<audio>/<video> must ship a captions <track>.",
    "url": "https://github.com/jsx-eslint/eslint-plugin-jsx-a11y/blob/main/docs/rules/media-has-caption.md"
  },
